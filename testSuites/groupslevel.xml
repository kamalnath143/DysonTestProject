<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite parallel="tests" name="All Test Suite">
    <groups>
        <run>
            <include name="SearchPage"/>
        </run>
    </groups>
    <test verbose="2" preserve-order="true" name="Check Out Product Test">
        <classes>
            <class name="DysonTest.CheckOutProductTest"/>
        </classes>
    </test>
    <test verbose="2" preserve-order="true" name="Search Product">
        <classes>
            <class name="DysonTest.DysonSearchProduct"/>
        </classes>
    </test>
</suite>